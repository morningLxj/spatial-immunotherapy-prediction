@article{liSpatialTranscriptomicsTumor2022,
  title = {Spatial Transcriptomics for Tumor Heterogeneity Analysis},
  author = {Li, Qiongyu and Zhang, Xinya and Ke, Rongqin},
  year = 2022,
  month = jul,
  journal = {Frontiers in Genetics},
  volume = {13},
  publisher = {Frontiers},
  issn = {1664-8021},
  doi = {10.3389/fgene.2022.906158},
  urldate = {2025-12-16},
  abstract = {The molecular heterogeneity of cancer is one of the major causes of drug resistance that leads to treatment failure. Thus, better understanding the heterogeneity of cancer will contribute to more precise diagnosis and improved patient outcomes. Although single-cell sequencing has become an important tool for investigating tumor heterogeneity recently, it lacks the spatial information of the analyzed cells. In this regard, spatial transcriptomics holds great promises in deciphering the complexed heterogeneity of cancer by providing localization-indexed gene expression information. This paper reviews the applications of spatial transcriptomics in the study of tumor heterogeneity, discovery of novel spatial dependent mechanisms, tumor immune microenvironment and matrix microenvironment as well as the pathological classification and prognosis of cancer. Finally, future challenges and opportunities for applications of spatial transcriptomics technologies in cancer are also discussed.},
  langid = {english},
  keywords = {Application.,Cancer,heterogeneity,Spatial transcriptomics,Tumor Microenvironment},
  annotation = {TLDR: The applications of spatial transcriptomics in the study of tumor heterogeneity, discovery of novel spatial-dependent mechanisms, tumor immune micro environment, and matrix microenvironment, as well as the pathological classification and prognosis of cancer are reviewed.},
  file = {files/957/Li 等 - 2022 - Spatial transcriptomics for tumor heterogeneity analysis.pdf}
}


